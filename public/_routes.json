{
  "version": 1,
  "include": [
    "/*"
  ],
  "exclude": [
    "/api/*",
    "/_next/static/*",
    "/_next/image/*",
    "/public/*",
    "/favicon.ico",
    "/robots.txt",
    "/sitemap.xml"
  ],
  "rules": [
    {
      "type": "rewrite",
      "pattern": "^/api/.*$",
      "origin": {
        "kind": "fetch"
      }
    }
  ]
}
